# Required in production — change this
JWT_SECRET=dev-secret-change-in-production

# Port for the HTTP auth server
PORT=3000

# Set to "true" to skip ERC-8004 identity check (week 1 testing)
BYPASS_IDENTITY=true

# Set to "false" once you have real ERC-8004 identities on Base Sepolia
BYPASS_REPUTATION=true
